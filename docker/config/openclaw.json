{
  "gateway": {
    "auth": {
      "mode": "none"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "moonshot/kimi-k2.5"
      },
      "models": {
        "moonshot/kimi-k2.5": {
          "alias": "Kimi K2.5"
        }
      },
      "compaction": {
        "model": "moonshot/kimi-k2.5"
      },
      "blockStreamingDefault": "on",
      "blockStreamingBreak": "text_end",
      "blockStreamingChunk": {
        "minChars": 200,
        "maxChars": 500
      },
      "pruning": {
        "enabled": true,
        "maxAge": 10
      }
    }
  },
  "browser": {
    "cdpUrl": "http://127.0.0.1:18800",
    "attachOnly": true,
    "noSandbox": true
  },
  "skills": {
    "allowBundled": [
      "canvas", "clawhub", "gh-issues", "github", "healthcheck",
      "himalaya", "mcporter", "nano-pdf", "node-connect", "notion",
      "obsidian", "openai-whisper", "oracle", "session-logs",
      "sherpa-onnx-tts", "skill-creator", "summarize", "tmux",
      "trello", "video-frames", "weather", "camsnap", "1password"
    ],
    "load": {
      "extraDirs": ["/mnt/platform/skills"]
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "moonshot": {
        "baseUrl": "https://api.moonshot.cn/v1",
        "apiKey": "",
        "api": "openai-completions",
        "models": [
          {
            "id": "kimi-k2.5",
            "name": "Kimi K2.5",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 262144,
            "maxTokens": 32768
          }
        ]
      }
    }
  }
}
